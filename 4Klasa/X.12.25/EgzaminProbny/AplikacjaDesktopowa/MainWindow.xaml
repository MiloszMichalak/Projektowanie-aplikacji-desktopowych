<Window x:Class="AplikacjaDesktopowa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AplikacjaDesktopowa"
        mc:Ignorable="d"
        Title="Konwerter Jednostek. Wykonal: 19" Height="450" Width="800"
        Background="LightGray">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="6*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <TabControl x:Name="TabControl" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" SelectionChanged="TabControl_OnSelectionChanged">
            <TabItem Header="Dlugosc"></TabItem>
            <TabItem Header="Masa"></TabItem>
            <TabItem Header="Temperatura"></TabItem>
        </TabControl>
        
        <TextBox x:Name="BaseValue" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="0" TextAlignment="Right"></TextBox>
        
        <ComboBox x:Name="BaseComboBox" Grid.Row="2" Grid.Column="0"></ComboBox>
        <ComboBox x:Name="TargetComboBox" Grid.Row="2" Grid.Column="1"></ComboBox>
        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="Konwertuj" Click="ConvertBtn_OnClick" Background="CornflowerBlue"></Button>
        <Label x:Name="ConvertedText" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" Background="White"></Label>
        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="Wyczysc" Background="Salmon" Click="ButtonBase_OnClick"></Button>
        <ListBox x:Name="ListBox" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"></ListBox>
    </Grid>
</Window>
